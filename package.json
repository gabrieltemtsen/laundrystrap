{
  "name": "laundrystrap",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.2.0",
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:ops": "pnpm --filter ops dev",

    "build:web": "pnpm --filter web build",
    "build:ops": "pnpm --filter ops build",
    "build": "pnpm -r --filter web --filter ops build",

    "lint": "pnpm -r --filter web --filter ops lint",
    "type-check": "pnpm -r --filter web --filter ops type-check"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "prettier": "^3.2.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
